# AUDIT_PROVIDER: Selects the analysis engine used by the backend.
# The current implementation uses a local heuristic engine and does not require a third-party API key.
AUDIT_PROVIDER="local"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# RESEARCHER_MODE: Set to "true" to enable advanced forensic metrics and raw data exports.
RESEARCHER_MODE="true"

# DATA_EXPORT_TIER: Defines the fidelity of exported datasets (e.g., "standard", "high", "raw").
DATA_EXPORT_TIER="high"

# RESEARCH_MODEL_ID: Optional pin to a specific psychiatric research model id from config/research-models.json.
# Example: "psychiatric-evidence-v1-strict"
RESEARCH_MODEL_ID=""

# RESEARCH_MODELS_FILE: Optional override path for the psychiatric research model registry JSON file.
RESEARCH_MODELS_FILE="config/research-models.json"

# CORS_ALLOWED_ORIGINS: Optional comma-separated allowlist for browser origins.
# Leave empty in local development if needed.
CORS_ALLOWED_ORIGINS=""

# API_RATE_LIMIT_MAX and API_RATE_LIMIT_WINDOW_MS: Basic in-memory API throttling controls.
API_RATE_LIMIT_MAX="120"
API_RATE_LIMIT_WINDOW_MS="60000"

# MAX_TRANSCRIPT_CHARS and MAX_NOTES_CHARS: Input size limits for privacy and abuse prevention.
MAX_TRANSCRIPT_CHARS="50000"
MAX_NOTES_CHARS="2000"

# ENABLE_HSTS: Adds Strict-Transport-Security header in production.
ENABLE_HSTS="true"

# PRIVACY_HASH_RESEARCHER_ID: Hashes researcher IDs at rest in SQLite.
PRIVACY_HASH_RESEARCHER_ID="false"

# PRIVACY_STORE_RAW_DATA: When false, stores minimized summary payloads instead of full analysis payloads.
PRIVACY_STORE_RAW_DATA="true"

# PRIVACY_PII_SCRUBBER_ENABLED: Enables automated PII redaction for audit inputs and session notes.
PRIVACY_PII_SCRUBBER_ENABLED="true"
